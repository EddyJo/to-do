{
  "title": "Todo App — SLO",
  "uid": "todo-slo",
  "schemaVersion": 38,
  "refresh": "1m",
  "tags": ["todo-app", "slo"],
  "panels": [
    {
      "title": "API Availability (target: 99.9%)",
      "type": "gauge",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "1 - (sum(rate(http_requests_total{status=~\"5..\"}[30d])) / sum(rate(http_requests_total[30d])))"
      }],
      "options": { "thresholds": [{ "value": 0.999, "color": "green" }, { "value": 0.99, "color": "yellow" }, { "value": 0, "color": "red" }] }
    },
    {
      "title": "API p95 Latency (target: <200ms)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[5m])) by (le))"
      }]
    },
    {
      "title": "AI Extraction p95 (target: <5s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(todo_ai_extraction_duration_ms_bucket[5m])) by (le))"
      }]
    },
    {
      "title": "Error Budget Burn Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1h])) / sum(rate(http_requests_total[1h]))"
      }]
    }
  ]
}
