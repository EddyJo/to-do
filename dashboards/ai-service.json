{
  "title": "Todo App — AI Service",
  "uid": "todo-ai-service",
  "schemaVersion": 38,
  "refresh": "30s",
  "tags": ["todo-app", "ai"],
  "panels": [
    {
      "title": "Memo Extraction Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(todo_ai_extraction_requests_total[1m]))" }]
    },
    {
      "title": "Extraction p95 Latency (target: <5s)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(todo_ai_extraction_duration_ms_bucket[5m])) by (le))"
      }]
    },
    {
      "title": "AI Error Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(todo_ai_extraction_requests_total{status=\"error\"}[5m]))" }]
    },
    {
      "title": "User Approval Rate",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{
        "expr": "sum(rate(todo_ai_extraction_approved_total[1h])) / sum(rate(todo_ai_extraction_requests_total[1h]))"
      }]
    },
    {
      "title": "AI Fallback (graceful degradation) Count",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(increase(todo_ai_fallback_total[1h]))" }]
    },
    {
      "title": "Extraction Logs",
      "type": "logs",
      "datasource": "Loki",
      "targets": [{ "expr": "{service=\"todo-ai\"} |= \"extraction\"" }]
    }
  ]
}
