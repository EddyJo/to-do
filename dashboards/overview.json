{
  "title": "Todo App — Overview",
  "uid": "todo-overview",
  "schemaVersion": 38,
  "refresh": "30s",
  "tags": ["todo-app", "overview"],
  "panels": [
    {
      "title": "API Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(http_requests_total[1m])) by (route)" }]
    },
    {
      "title": "API Error Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) by (route)" }]
    },
    {
      "title": "API p95 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))" }]
    },
    {
      "title": "Active Sessions",
      "type": "stat",
      "datasource": "Prometheus",
      "targets": [{ "expr": "todo_api_active_sessions_total" }]
    }
  ]
}
